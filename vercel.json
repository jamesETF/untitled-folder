{
  "builds": [
    {
      "src": "Gemfile",
      "use": "@vercel/ruby"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "_site",
        "buildCommand": "bundle exec jekyll build"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
